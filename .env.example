# Copy to .env and adjust (do not commit .env).
# Load before running:  export $(grep -v '^#' .env | xargs)   # bash/zsh

# --- Option A: single URL (recommended) ---
# DATABASE_URL=postgresql://user:password@localhost:5432/your_db

# --- Option B: discrete connection ---
# GSAQ_PG_HOST=localhost
# GSAQ_PG_PORT=5432
# GSAQ_PG_DB=your_db
# GSAQ_PG_USER=your_user
# GSAQ_PG_PASSWORD=

# --- Table / column mapping (match your DDL; defaults below are common Tushare-style names) ---
# GSAQ_PG_SCHEMA=public
# GSAQ_PG_TABLE=stock_daily
# GSAQ_PG_CODE_COLUMN=ts_code
# GSAQ_PG_DATE_COLUMN=trade_date
# GSAQ_PG_OPEN_COLUMN=open
# GSAQ_PG_HIGH_COLUMN=high
# GSAQ_PG_LOW_COLUMN=low
# GSAQ_PG_CLOSE_COLUMN=close
# GSAQ_PG_VOLUME_COLUMN=vol
# GSAQ_PG_AMOUNT_COLUMN=amount
# If you have no amount column, set:
# GSAQ_PG_AMOUNT_COLUMN=
